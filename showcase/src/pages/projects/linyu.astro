---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import Mascot from '../../components/Mascot.astro';
import ExtensionPopup from '../../components/ExtensionPopup.astro';
import BrowserMockup from '../../components/BrowserMockup.astro';
import Footer from '../../components/Footer.astro';
import { linyu } from '../../data/project';

// 换成真实立绘即可：例如 "/assets/linyu-point.png"
const pose = { point: undefined, think: undefined, stand: undefined };
---

<Base>
  <div class="detail container">
    <!-- ============ Sidebar ============ -->
    <aside class="side">
      <div class="side__sticky">
        <a class="side__brand" href="/">
          <span class="side__logo"><Icon name="feather" size={20} /></span>
          <span class="side__name">
            <strong class="display">Linyu</strong>
            <small class="cjk">灵羽</small>
          </span>
        </a>

        <nav class="side__nav" aria-label="Sections">
          {linyu.toc.map((t) => (
            <a href={`#${t.id}`} data-link={t.id}>{t.label}</a>
          ))}
        </nav>

        <div class="side__cta">
          <a class="btn btn-primary" href={linyu.links.liveDemo}><Icon name="external" size={16} /> Live Demo</a>
          <a class="btn btn-ghost" href={linyu.links.sourceCode}><Icon name="github" size={16} /> Source Code</a>
        </div>
      </div>
    </aside>

    <!-- ============ Main ============ -->
    <main class="main">
      <!-- breadcrumb -->
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><a href="/#projects">Projects</a><span>/</span><b>Linyu</b>
      </nav>

      <!-- ===== Hero ===== -->
      <header class="hero">
        <div class="hero__copy">
          <div class="hero__pills">
            {linyu.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          <h1 class="hero__title display">
            Linyu <span class="hero__cjk cjk">灵羽</span>
          </h1>
          <p class="hero__tagline">{linyu.tagline}</p>
          <p class="hero__desc">{linyu.description}</p>
          <div class="hero__btns">
            <a class="btn btn-primary" href={linyu.links.sourceCode}><Icon name="github" size={17} /> Open GitHub</a>
            <a class="btn btn-ghost" href={linyu.links.documentation}><Icon name="notes" size={17} /> Read README</a>
          </div>
          <ul class="hero__highlights">
            {linyu.highlights.map((h) => (
              <li>
                <span class="hero__hicon"><Icon name={h.icon} size={18} /></span>
                <div><strong>{h.title}</strong><small>{h.text}</small></div>
              </li>
            ))}
          </ul>
        </div>

        <div class="hero__visual">
          <BrowserMockup class="hero__browser" />
          <ExtensionPopup width={264} class="hero__popup" />
          <div class="hero__bubble">Turn your insights into polished docs.</div>
          <Mascot src={pose.point} size={186} class="hero__mascot" />
        </div>
      </header>

      <!-- ===== Overview ===== -->
      <section id="overview" class="sec">
        <p class="eyebrow">01 — Overview</p>
        <h2 class="section-title">What Linyu does</h2>
        <div class="grid3">
          {linyu.overview.map((o) => (
            <div class="card feature">
              <span class="feature__icon"><Icon name={o.icon} size={22} /></span>
              <h3>{o.title}</h3>
              <p>{o.text}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ===== Problem ===== -->
      <section id="problem" class="sec">
        <p class="eyebrow">02 — Problem</p>
        <h2 class="section-title">Publishing is messy today</h2>
        <div class="card problem">
          <div class="problem__mascot">
            <Mascot src={pose.think} size={150} flip />
          </div>
          <ul class="problem__list">
            {linyu.problems.map((p) => (
              <li>
                <span class="problem__icon"><Icon name={p.icon} size={18} /></span>
                {p.text}
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ===== Workflow ===== -->
      <section id="workflow" class="sec">
        <p class="eyebrow">03 — Workflow</p>
        <h2 class="section-title">From input to long-form, in 5 steps</h2>
        <div class="flow">
          {linyu.workflow.map((w, i) => (
            <>
              <div class="flow__step">
                <span class="flow__num">{w.step}</span>
                <h3>{w.title}</h3>
                <div class="flow__mini" data-k={w.step}>
                  <i></i><i></i><i></i>
                </div>
                <p>{w.text}</p>
              </div>
              {i < linyu.workflow.length - 1 && <span class="flow__arrow"><Icon name="arrow" size={18} /></span>}
            </>
          ))}
        </div>
      </section>

      <!-- ===== Key Screens ===== -->
      <section id="screens" class="sec">
        <p class="eyebrow">04 — Key Screens</p>
        <h2 class="section-title">Key screens</h2>
        <div class="grid4">
          <figure class="shot">
            <div class="shot__frame shot--popup">
              <div class="shot__bar"><span></span><b>Linyu</b></div>
              <div class="shot__rows"><i></i><i></i><i></i></div>
              <div class="shot__btn"></div>
            </div>
            <figcaption>1. Extension Popup</figcaption>
          </figure>
          <figure class="shot">
            <div class="shot__frame shot--preview">
              <div class="shot__hero"></div>
              <div class="shot__grid"><span></span><span></span><span></span></div>
              <i></i><i style="width:70%"></i>
            </div>
            <figcaption>2. Content Preview</figcaption>
          </figure>
          <figure class="shot">
            <div class="shot__frame shot--adapters">
              <div class="shot__toggle"><span class="shot__sw on"></span><i></i></div>
              <div class="shot__toggle"><span class="shot__sw on"></span><i></i></div>
              <div class="shot__toggle"><span class="shot__sw"></span><i></i></div>
              <div class="shot__confirm"><Icon name="checkCircle" size={16} /> Ready to confirm</div>
            </div>
            <figcaption>3. Platform Adapters</figcaption>
          </figure>
          <figure class="shot">
            <div class="shot__frame shot--editor">
              <div class="shot__tools"><b></b><b></b><b></b><b></b></div>
              <i></i><i style="width:84%"></i>
              <div class="shot__img"></div>
              <i style="width:76%"></i>
            </div>
            <figcaption>4. Editor Fill &amp; Confirm</figcaption>
          </figure>
        </div>
      </section>

      <!-- ===== Local-first ===== -->
      <section id="local-first" class="sec">
        <p class="eyebrow">05 — Local-first</p>
        <h2 class="section-title">Local-first by default</h2>
        <p class="lede">All history and drafts are stored locally in your browser.</p>
        <div class="local">
          <div class="local__mascot"><Mascot src={pose.stand} size={172} /></div>

          <div class="card local__history">
            <div class="local__h"><strong>History</strong><span class="local__search"><Icon name="search" size={14} /></span></div>
            <ul>
              <li><Icon name="notes" size={15} /><i></i><time>05/26 · 14:32</time><span class="dot"></span></li>
              <li><Icon name="notes" size={15} /><i></i><time>05/25 · 10:11</time><span class="dot"></span></li>
              <li><Icon name="notes" size={15} /><i></i><time>05/24 · 18:05</time><span class="dot"></span></li>
              <li><Icon name="notes" size={15} /><i></i><time>05/23 · 09:47</time><span class="dot"></span></li>
              <li><Icon name="notes" size={15} /><i></i><span class="badge draft">Draft</span><time>05/20</time></li>
            </ul>
          </div>

          <div class="card local__store">
            <strong>Storage Location</strong>
            <div class="local__diagram">
              <span class="local__node"><Icon name="user" size={20} /></span>
              <span class="local__wire"></span>
              <span class="local__node local__node--db"><Icon name="folder" size={20} /></span>
            </div>
            <div class="local__chips"><span class="tag is-blue">This Browser Profile</span><span class="tag">Stored Locally</span></div>
            <div class="local__clear">
              <button class="btn local__danger" type="button"><Icon name="trash" size={15} /> Clear</button>
              <button class="btn btn-ghost" type="button"><Icon name="shield" size={15} /> Manual Confirm</button>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== Tech Stack ===== -->
      <section id="tech" class="sec">
        <p class="eyebrow">06 — Tech Stack</p>
        <h2 class="section-title">Built with</h2>
        <div class="stack">
          {linyu.techStack.map((t) => <span class="stack__item"><Icon name="code" size={15} /> {t}</span>)}
        </div>
      </section>

      <!-- ===== Links ===== -->
      <section id="links" class="sec">
        <p class="eyebrow">07 — Links</p>
        <h2 class="section-title">Links</h2>
        <div class="links">
          <a class="links__row" href={linyu.links.liveDemo}><span class="links__ic"><Icon name="external" size={18} /></span><b>Live Demo</b><Icon name="arrow" size={17} class="links__go" /></a>
          <a class="links__row" href={linyu.links.sourceCode}><span class="links__ic"><Icon name="github" size={18} /></span><b>Source Code</b><Icon name="arrow" size={17} class="links__go" /></a>
          <a class="links__row" href={linyu.links.documentation}><span class="links__ic"><Icon name="notes" size={18} /></span><b>Documentation</b><Icon name="arrow" size={17} class="links__go" /></a>
          <a class="links__row" href={linyu.links.changelog}><span class="links__ic"><Icon name="clock" size={18} /></span><b>Changelog</b><Icon name="arrow" size={17} class="links__go" /></a>
        </div>
      </section>
    </main>
  </div>

  <Footer />
</Base>

<style>
  .detail {
    display: grid;
    grid-template-columns: 232px minmax(0, 1fr);
    gap: 48px;
    padding-top: 36px;
    padding-bottom: 20px;
    align-items: start;
  }
  .main { min-width: 0; }

  /* —— sidebar —— */
  .side__sticky { position: sticky; top: 32px; display: flex; flex-direction: column; gap: 22px; }
  .side__brand { display: flex; align-items: center; gap: 12px; }
  .side__logo {
    width: 44px; height: 44px; display: grid; place-items: center;
    background: var(--purple-soft); color: var(--purple-strong); border-radius: 13px;
  }
  .side__name { display: flex; flex-direction: column; line-height: 1.1; }
  .side__name strong { font-size: 22px; }
  .side__name small { color: var(--ink-3); font-size: 15px; }

  .side__nav { display: flex; flex-direction: column; gap: 2px; }
  .side__nav a {
    padding: 9px 12px; border-radius: 9px; color: var(--ink-2); font-weight: 500; font-size: 15px;
    border-left: 2px solid transparent; transition: background 0.15s ease, color 0.15s ease;
  }
  .side__nav a:hover { background: var(--card-soft); color: var(--ink); }
  .side__nav a.is-active { color: var(--accent); background: var(--accent-soft); font-weight: 600; }

  .side__cta { display: flex; flex-direction: column; gap: 10px; }
  .side__cta .btn { width: 100%; justify-content: center; }

  /* —— breadcrumb —— */
  .crumbs { display: flex; align-items: center; gap: 9px; color: var(--ink-3); font-size: 14px; margin-bottom: 22px; }
  .crumbs a:hover { color: var(--accent); }
  .crumbs b { color: var(--ink); }

  /* —— hero —— */
  .hero { display: grid; grid-template-columns: 1fr 1fr; gap: 36px; align-items: center; margin-bottom: 26px; }
  .hero__pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .hero__title { font-size: clamp(46px, 6vw, 76px); line-height: 0.98; letter-spacing: -0.02em; }
  .hero__cjk { font-weight: 700; }
  .hero__tagline { font-family: var(--font-display); font-size: clamp(22px, 2.6vw, 30px); color: var(--ink); margin-top: 10px; }
  .hero__desc { color: var(--ink-2); font-size: 16px; margin-top: 14px; max-width: 44ch; }
  .hero__btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
  .hero__highlights { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 26px; padding-top: 22px; border-top: 1px solid var(--border-soft); }
  .hero__highlights li { display: flex; gap: 10px; align-items: center; }
  .hero__hicon { width: 34px; height: 34px; flex: none; display: grid; place-items: center; background: var(--card-soft); border: 1px solid var(--border-soft); color: var(--accent); border-radius: 10px; }
  .hero__highlights strong { display: block; font-size: 14px; }
  .hero__highlights small { color: var(--ink-3); font-size: 12.5px; }

  .hero__visual { position: relative; min-height: 380px; }
  .hero__browser { position: absolute; right: 0; top: 14px; width: 96%; }
  .hero__popup { position: absolute; left: -18px; top: 44px; z-index: 3; }
  .hero__bubble {
    position: absolute; right: 6px; top: -6px; z-index: 4; max-width: 150px;
    background: #fff; border: 1px solid var(--border); border-radius: 14px 14px 14px 4px;
    padding: 10px 13px; font-size: 13px; color: var(--ink-2); box-shadow: var(--shadow-md);
  }
  .hero__mascot { position: absolute; right: -10px; bottom: -16px; z-index: 4; }

  /* —— sections —— */
  .sec { margin-top: 64px; scroll-margin-top: 88px; }
  .sec .eyebrow { margin-bottom: 8px; }
  .sec .section-title { margin-bottom: 22px; }
  .sec .lede { margin: -10px 0 22px; }

  .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .feature { padding: 22px; }
  .feature__icon { width: 44px; height: 44px; display: grid; place-items: center; background: var(--accent-soft); color: var(--accent); border-radius: 12px; margin-bottom: 14px; }
  .feature h3 { font-size: 17px; margin-bottom: 7px; }
  .feature p { color: var(--ink-2); font-size: 14.5px; }

  /* —— problem —— */
  .problem { display: grid; grid-template-columns: 200px 1fr; gap: 24px; align-items: center; padding: 24px 28px; background: var(--card-sunken); }
  .problem__mascot { display: grid; place-items: center; }
  .problem__list { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .problem__list li { display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid var(--border-soft); border-radius: 12px; padding: 14px 16px; font-weight: 500; }
  .problem__icon { width: 34px; height: 34px; flex: none; display: grid; place-items: center; background: var(--accent-soft); color: var(--accent); border-radius: 9px; }

  /* —— workflow —— */
  .flow { display: flex; align-items: stretch; gap: 6px; overflow-x: auto; padding-bottom: 6px; min-width: 0; }
  .flow__step { flex: 1 1 0; min-width: 150px; background: var(--card); border: 1px solid var(--border-soft); border-radius: 16px; padding: 18px 16px; text-align: center; box-shadow: var(--shadow-sm); }
  .flow__num { width: 30px; height: 30px; display: inline-grid; place-items: center; background: var(--accent); color: #fff; border-radius: 50%; font-weight: 700; font-size: 14px; margin-bottom: 10px; }
  .flow__step h3 { font-size: 16px; margin-bottom: 12px; }
  .flow__mini { background: var(--card-sunken); border-radius: 10px; padding: 12px; display: grid; gap: 6px; margin-bottom: 12px; min-height: 64px; align-content: center; }
  .flow__mini i { height: 7px; border-radius: 4px; background: #e3d8c4; }
  .flow__mini i:nth-child(2) { width: 80%; }
  .flow__mini i:nth-child(3) { width: 60%; }
  .flow__mini[data-k="2"] i:last-child { background: var(--purple); width: 40%; }
  .flow__mini[data-k="3"] i:nth-child(2) { background: var(--green); }
  .flow__mini[data-k="4"] i:first-child { background: var(--accent); }
  .flow__step p { color: var(--ink-2); font-size: 13px; }
  .flow__arrow { display: grid; place-items: center; color: var(--accent); flex: none; align-self: center; }

  /* —— key screens —— */
  .grid4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .shot figcaption { text-align: center; margin-top: 12px; font-size: 14px; color: var(--ink-2); font-weight: 600; }
  .shot__frame { background: #fff; border: 1px solid var(--border-soft); border-radius: 14px; box-shadow: var(--shadow-sm); padding: 14px; height: 184px; display: flex; flex-direction: column; gap: 8px; overflow: hidden; }
  .shot__frame i { height: 8px; border-radius: 4px; background: #ece2cf; display: block; width: 100%; }
  .shot__bar { display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 700; color: var(--ink-2); }
  .shot__bar span { width: 16px; height: 16px; border-radius: 5px; background: var(--purple-soft); }
  .shot__rows { display: grid; gap: 7px; flex: 1; align-content: start; }
  .shot__rows i { background: var(--card-sunken); height: 22px; border-radius: 7px; }
  .shot__btn { height: 26px; border-radius: 8px; background: linear-gradient(180deg, #8b7cf6, var(--purple-strong)); }
  .shot__hero { height: 60px; border-radius: 9px; background: linear-gradient(135deg, #cdb7f0, #8e9ddb); }
  .shot__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .shot__grid span { aspect-ratio: 1; border-radius: 6px; background: var(--card-sunken); }
  .shot__toggle { display: flex; align-items: center; gap: 9px; }
  .shot__toggle i { flex: 1; }
  .shot__sw { width: 30px; height: 18px; border-radius: 999px; background: #ddd0ba; position: relative; flex: none; }
  .shot__sw::after { content: ''; position: absolute; width: 14px; height: 14px; border-radius: 50%; background: #fff; top: 2px; left: 2px; }
  .shot__sw.on { background: var(--purple); }
  .shot__sw.on::after { left: 14px; }
  .shot__confirm { margin-top: auto; display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 700; color: #357a4a; background: var(--green-soft); border-radius: 8px; padding: 8px 10px; }
  .shot__tools { display: flex; gap: 5px; }
  .shot__tools b { width: 18px; height: 18px; border-radius: 5px; background: var(--card-sunken); }
  .shot__img { height: 48px; border-radius: 8px; background: var(--card-sunken); }

  /* —— local-first —— */
  .local { display: grid; grid-template-columns: 190px 1fr 1fr; gap: 18px; align-items: start; }
  .local__mascot { display: grid; place-items: center; align-self: center; }
  .local__history { padding: 18px; }
  .local__h { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .local__search { width: 28px; height: 28px; display: grid; place-items: center; background: var(--card-soft); border: 1px solid var(--border-soft); border-radius: 8px; color: var(--ink-3); }
  .local__history ul { display: grid; gap: 9px; }
  .local__history li { display: flex; align-items: center; gap: 10px; color: var(--ink-3); font-size: 12.5px; }
  .local__history li i { flex: 1; height: 8px; border-radius: 4px; background: #ece2cf; }
  .local__history time { color: var(--ink-3); white-space: nowrap; }
  .local__history .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); flex: none; }
  .local__store { padding: 18px; }
  .local__store > strong { display: block; margin-bottom: 14px; }
  .local__diagram { display: flex; align-items: center; gap: 6px; justify-content: center; margin-bottom: 14px; }
  .local__node { width: 52px; height: 52px; display: grid; place-items: center; background: var(--card-soft); border: 1px solid var(--border-soft); border-radius: 14px; color: var(--purple-strong); }
  .local__node--db { color: var(--blue); }
  .local__wire { flex: 1; max-width: 70px; height: 2px; background: repeating-linear-gradient(90deg, var(--accent) 0 6px, transparent 6px 12px); }
  .local__chips { display: flex; gap: 8px; justify-content: center; margin-bottom: 16px; flex-wrap: wrap; }
  .local__clear { display: grid; gap: 9px; }
  .local__danger { background: #d8503f; color: #fff; justify-content: center; }
  .local__danger:hover { background: #c2422f; }
  .local__clear .btn-ghost { justify-content: center; }

  /* —— tech —— */
  .stack { display: flex; flex-wrap: wrap; gap: 10px; }
  .stack__item { display: inline-flex; align-items: center; gap: 8px; background: var(--card); border: 1px solid var(--border-soft); border-radius: 11px; padding: 10px 15px; font-weight: 600; font-size: 14.5px; box-shadow: var(--shadow-sm); }
  .stack__item :global(svg) { color: var(--purple-strong); }

  /* —— links —— */
  .links { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .links__row { display: flex; align-items: center; gap: 14px; background: var(--card); border: 1px solid var(--border-soft); border-radius: 13px; padding: 16px 18px; font-size: 16px; box-shadow: var(--shadow-sm); transition: border-color 0.16s ease, transform 0.16s ease; }
  .links__row:hover { border-color: var(--accent); transform: translateY(-2px); }
  .links__row b { flex: 1; }
  .links__ic { width: 38px; height: 38px; display: grid; place-items: center; background: var(--accent-soft); color: var(--accent); border-radius: 10px; }
  .links__go { color: var(--ink-3); }
  .links__row:hover .links__go { color: var(--accent); }

  /* —— responsive —— */
  @media (max-width: 1080px) {
    .hero { grid-template-columns: 1fr; }
    .hero__visual { min-height: 340px; margin-top: 8px; }
    .grid4 { grid-template-columns: repeat(2, 1fr); }
    .local { grid-template-columns: 1fr 1fr; }
    .local__mascot { grid-column: 1 / -1; }
  }
  @media (max-width: 860px) {
    .detail { grid-template-columns: minmax(0, 1fr); gap: 0; }
    .side { position: sticky; top: 0; z-index: 40; margin: -36px 0 10px; padding: 12px 0; background: rgba(248,241,231,0.96); border-bottom: 1px solid var(--border-soft); }
    .side__sticky { position: static; flex-direction: row; align-items: center; gap: 14px; flex-wrap: wrap; }
    .side__nav { flex-direction: row; flex-wrap: wrap; gap: 4px; order: 3; flex-basis: 100%; }
    .side__nav a { padding: 6px 10px; font-size: 13.5px; }
    .side__cta { flex-direction: row; margin-left: auto; }
    .side__cta .btn { width: auto; }
  }
  @media (max-width: 620px) {
    .grid3 { grid-template-columns: 1fr; }
    .problem { grid-template-columns: 1fr; }
    .problem__list { grid-template-columns: 1fr; }
    .grid4 { grid-template-columns: 1fr; }
    .local { grid-template-columns: 1fr; }
    .links { grid-template-columns: 1fr; }
    .hero__title { font-size: 56px; }
    .side__cta .btn span { display: none; }
  }
</style>

<script>
  // 滚动高亮当前章节
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.side__nav a'));
  const map = new Map(links.map((l) => [l.dataset.link, l]));
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          links.forEach((l) => l.classList.remove('is-active'));
          map.get(e.target.id)?.classList.add('is-active');
        }
      });
    },
    { rootMargin: '-30% 0px -60% 0px' }
  );
  document.querySelectorAll('.sec[id]').forEach((s) => obs.observe(s));
</script>
